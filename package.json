{
  "name": "beyondfit",
  "version": "0.1.0",
  "private": true,
  "description": "AI-powered body-aware style recommendations platform",
  "workspaces": [
    "web",
    "mobile",
    "shared"
  ],
  "scripts": {
    "dev": "npm-run-all --parallel dev:*",
    "dev:web": "cd web && npm run dev",
    "dev:backend": "cd backend && python -m uvicorn app.main:app --reload",
    "build": "npm-run-all build:*",
    "build:web": "cd web && npm run build",
    "build:mobile": "cd mobile && npm run build",
    "test": "npm-run-all test:*",
    "test:backend": "cd backend && pytest",
    "test:web": "cd web && npm test",
    "lint": "npm-run-all lint:*",
    "lint:web": "cd web && npm run lint",
    "lint:mobile": "cd mobile && npm run lint"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  }
}
