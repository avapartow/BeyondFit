# Application
APP_NAME=BeyondFit
APP_ENV=development
DEBUG=True
API_VERSION=v1

# Server
HOST=0.0.0.0
PORT=8000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:19006

# Database (Supabase or local Postgres)
DATABASE_URL=postgresql://user:password@localhost:5432/beyondfit
# Supabase example:
# DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# Auth
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Supabase (for Auth + Storage)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# Storage (S3-compatible)
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=us-east-1
S3_BUCKET_NAME=beyondfit-photos
S3_ENDPOINT_URL=  # Leave empty for AWS, or use custom endpoint for other providers

# Photos - Privacy settings
DELETE_PHOTOS_AFTER_PROCESSING=True
PHOTO_RETENTION_HOURS=0  # 0 = delete immediately

# Email (for OTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
FROM_EMAIL=noreply@beyondfit.com

# Affiliate tracking
AFFILIATE_CLICK_TRACKING=True
AFFILIATE_CONVERSION_WEBHOOK=  # Optional webhook for conversion tracking

# Rate limiting
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_PER_HOUR=1000

# Feature flags
ENABLE_ADMIN_API=True
ENABLE_ANALYTICS=True
